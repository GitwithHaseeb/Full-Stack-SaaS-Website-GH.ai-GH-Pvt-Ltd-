# Local run: PostgreSQL + Redis. Copy to `.env` and edit values.
#
# PostgreSQL is required — SQLAlchemy uses asyncpg. URL MUST start with:
#   postgresql+asyncpg://
# If Neon/Supabase/Railway give postgresql://..., change only that prefix.
#
# Example (Neon-style — not a real host):
# DATABASE_URL=postgresql+asyncpg://user:pass@ep-xxxx.region.aws.neon.tech/neondb?ssl=require

DATABASE_URL=postgresql+asyncpg://postgres:postgres@127.0.0.1:5432/ghai
REDIS_URL=redis://127.0.0.1:6379/0
CELERY_BROKER_URL=redis://127.0.0.1:6379/0
CELERY_RESULT_BACKEND=redis://127.0.0.1:6379/0

SECRET_KEY=your_secret_key_change_in_production_min_32_chars_long
OPENAI_API_KEY=
GMAIL_CLIENT_ID=
GMAIL_CLIENT_SECRET=
# PAT needs at least: users:read, event_types:read, scheduling_links:write (webhooks:* if registering via API).
CALENDLY_PERSONAL_TOKEN=

ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7
CORS_ORIGINS=http://localhost:3000
